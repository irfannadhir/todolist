generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  PENDING
  ON_PROGRESS
  HOLD
  DONE
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime
  dueTime     String?
  dateFrom    DateTime?
  dateTo      DateTime?
  isRecurring Boolean    @default(false)
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([dueDate])
  @@index([status])
  @@index([userId])
  @@map("tasks")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  tasks        Task[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
